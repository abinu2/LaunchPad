# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Uses Neon Serverless Postgres — get your connection string at https://neon.tech
# Format: postgresql://user:password@host.neon.tech/dbname?sslmode=require
# Copy the "Pooled connection" string from your Neon dashboard for Vercel deploys.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ─── Auth0 ────────────────────────────────────────────────────────────────────
# Create an app at https://manage.auth0.com → Applications → Create Application
# Set Allowed Callback URLs to: https://your-domain.com/api/auth/callback
# Set Allowed Logout URLs to:   https://your-domain.com
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
# Generate with: openssl rand -hex 32
AUTH0_SECRET=your_32_char_random_secret
AUTH0_BASE_URL=https://your-domain.com

# ─── AI (OpenRouter — primary) ────────────────────────────────────────────────
# OpenRouter gives access to Gemini 2.0 Flash, Qwen, Claude, and 200+ models.
# All AI features route through OpenRouter when this key is set.
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key
# Override model tiers (optional — defaults shown)
# AI_MODEL=google/gemini-2.0-flash-001
# AI_VISION_MODEL=google/gemini-2.0-flash-001

# ─── AI (Groq — fallback) ─────────────────────────────────────────────────────
# Used if OPENROUTER_API_KEY is not set. Free tier available.
# Get your key: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key

# ─── Plaid ────────────────────────────────────────────────────────────────────
# Bank account connections and transaction sync
# Sign up at https://dashboard.plaid.com
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
# Use "sandbox" for testing, "production" for live
PLAID_ENV=sandbox

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Optional — only needed for hosted quote payment links
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ─── Vercel Blob ──────────────────────────────────────────────────────────────
# Document storage for contracts, receipts, and uploads
# Create a store at: vercel.com → project → Storage → Blob → Create Store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here

# ─── Tiny Fish ────────────────────────────────────────────────────────────────
# Optional — web scraping for real-time funding opportunities
# Falls back to AI-generated opportunities if not configured
# Get your key: https://tinyfish.io
TINYFISH_API_KEY=your_tinyfish_api_key

# ─── Google Cloud / Vertex AI ─────────────────────────────────────────────────
# Optional — advanced AI analysis fallback
# https://console.cloud.google.com → Enable Vertex AI API
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id
GOOGLE_CLOUD_REGION=us-central1

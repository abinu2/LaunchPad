generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Business ─────────────────────────────────────────────────────────────────

model Business {
  id        String   @id @default(cuid())
  auth0Id   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Onboarding & Business Info ─────────────────────────────────────────────
  businessName           String
  businessType           String   @default("")
  businessDescription    String   @default("")
  naicsCode              String   @default("")
  entityType             String   @default("sole_prop")
  entityState            String   @default("")
  ein                    String?
  formationDate          String?
  businessAddress        Json     @default("{}")
  operatingJurisdictions Json     @default("[]")

  // ─── Owner / Personal Info ───────────────────────────────────────────────────
  ownerName           String  @default("")
  ownerEmail          String  @default("")
  ownerPhone          String  @default("")
  hasOtherJob         Boolean @default(false)
  estimatedW2Income   Float?
  isFirstTimeBusiness Boolean @default(true)

  // ─── Business Operations ─────────────────────────────────────────────────────
  serviceTypes        Json    @default("[]")
  targetMarket        String  @default("residential")
  usesPersonalVehicle Boolean @default(false)
  hasEmployees        Boolean @default(false)
  employeeCount       Int     @default(0)
  hasContractors      Boolean @default(false)
  contractorCount     Int     @default(0)

  // ─── Financial Snapshot ──────────────────────────────────────────────────────
  monthlyRevenueAvg   Float     @default(0)
  monthlyExpenseAvg   Float     @default(0)
  profitMargin        Float     @default(0)
  totalRevenueYTD     Float     @default(0)
  totalExpensesYTD    Float     @default(0)
  currentCashBalance  Float?
  financialsUpdatedAt DateTime?

  // ─── Onboarding Progress ─────────────────────────────────────────────────────
  onboardingStage String @default("idea")
  completedSteps  Json   @default("[]")

  // ─── Relations ───────────────────────────────────────────────────────────────
  contracts           Contract[]
  receipts            Receipt[]
  quotes              Quote[]
  complianceItems     ComplianceItem[]
  fundingOpportunities FundingOpportunity[]
  bankTransactions    BankTransaction[]
  plaidConnections    PlaidConnection[]
  growthActions       GrowthAction[]
  uploadedFiles       UploadedFile[]
  taxSummaries        TaxSummary[]
  profitAndLoss       ProfitAndLoss[]
  expenseCategories   ExpenseCategory[]
  policyAnalyses      PolicyAnalysis[]
  gapAnalyses         GapAnalysis[]
  coverageActionPlans CoverageActionPlan[]
}

// ─── Contracts ────────────────────────────────────────────────────────────────

model Contract {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Optional link to the source file in UploadedFile registry
  uploadedFileId String?
  uploadedFile   UploadedFile? @relation(fields: [uploadedFileId], references: [id], onDelete: SetNull)

  fileName                String
  fileUrl                 String
  fileType                String  @default("pdf")
  contractType            String  @default("other")
  counterpartyName        String
  effectiveDate           String?
  expirationDate          String?
  autoRenews              Boolean @default(false)
  autoRenewalDate         String?
  autoRenewalNoticePeriod Int?
  terminationNoticePeriod Int?
  totalValue              Float?
  monthlyValue            Float?
  healthScore             Int     @default(100)
  status                  String  @default("active")
  analysis                Json    @default("{}")
  obligations             Json    @default("[]")
}

// ─── Receipts ─────────────────────────────────────────────────────────────────

model Receipt {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Optional link to source file
  uploadedFileId String?
  uploadedFile   UploadedFile? @relation(fields: [uploadedFileId], references: [id], onDelete: SetNull)

  imageUrl           String
  vendor             String
  amount             Float
  date               String
  lineItems          Json    @default("[]")
  category           String  @default("other")
  taxClassification  String  @default("expense")
  businessPercentage Float   @default(100)
  deductibleAmount   Float   @default(0)
  taxNotes           String  @default("")
  isReconciled       Boolean @default(false)
  associatedMileage  Float?
  needsMoreInfo      Boolean @default(false)
  pendingQuestion    String?
}

// ─── Quotes ───────────────────────────────────────────────────────────────────

model Quote {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  clientName            String
  clientEmail           String    @default("")
  clientPhone           String    @default("")
  services              Json      @default("[]")
  subtotal              Float     @default(0)
  taxRate               Float     @default(0)
  taxAmount             Float     @default(0)
  total                 Float     @default(0)
  pricingAnalysis       Json?
  status                String    @default("draft")
  sentAt                DateTime?
  viewedAt              DateTime?
  acceptedAt            DateTime?
  paidAt                DateTime?
  contractGenerated     Boolean   @default(false)
  contractId            String?
  contractSignedAt      DateTime?
  stripePaymentIntentId String?
  paymentMethod         String?
  paymentUrl            String?
  scheduledDate         String?
  scheduledTime         String?
  scheduledAddress      String?
  followUpsSent         Int       @default(0)
  lastFollowUpAt        DateTime?
  nextFollowUpAt        DateTime?
}

// ─── Compliance ───────────────────────────────────────────────────────────────

model ComplianceItem {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  title                   String
  description             String
  jurisdiction            String
  jurisdictionName        String
  category                String
  isRequired              Boolean  @default(true)
  legalCitation           String?
  status                  String   @default("not_started")
  obtainedDate            String?
  expirationDate          String?
  renewalDate             String?
  renewalFrequency        String?
  daysUntilDue            Int?
  applicationUrl          String?
  cost                    Float?
  estimatedProcessingTime String?
  documentationRequired   Json     @default("[]")
  penaltyForNonCompliance String?
  reminderSent30Days      Boolean  @default(false)
  reminderSent14Days      Boolean  @default(false)
  reminderSent3Days       Boolean  @default(false)
  lastCheckedAt           DateTime @default(now())
  proofUrl                String?
}

// ─── Funding Opportunities ────────────────────────────────────────────────────

model FundingOpportunity {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  name                 String
  provider             String
  type                 String
  amountMin            Float   @default(0)
  amountMax            Float   @default(0)
  interestRate         String?
  repaymentTerms       String?
  eligibilityMatch     Int     @default(0)
  eligibilityCriteria  Json    @default("[]")
  applicationUrl       String
  applicationDeadline  String?
  status               String  @default("discovered")
  applicationProgress  Int     @default(0)
  prefilledFields      Json    @default("{}")
  fitScore             Int     @default(0)
  recommendation       String  @default("")
  estimatedTimeToApply String  @default("")
}

// ─── Bank Transactions ────────────────────────────────────────────────────────

model BankTransaction {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactionId String   @unique
  accountId     String
  amount        Float
  date          String
  name          String
  merchantName  String?
  category      Json     @default("[]")
  pending       Boolean  @default(false)
  paymentChannel String  @default("")
  personalFinanceCategory Json?
}

// ─── Plaid Connections ────────────────────────────────────────────────────────

model PlaidConnection {
  id              String    @id @default(cuid())
  businessId      String
  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  itemId          String    @unique
  accessToken     String
  institutionId   String
  institutionName String
  accounts        Json      @default("[]")
  status          String    @default("active")
  errorCode       String?
  lastSyncedAt    DateTime?
}

// ─── Growth Actions ───────────────────────────────────────────────────────────

model GrowthAction {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  type       String
  title      String
  impact     String
  reasoning  String
  urgency    String   @default("medium")
  effort     String   @default("medium")
  dismissed  Boolean  @default(false)
}

// ─── Tax Summaries ────────────────────────────────────────────────────────────

model TaxSummary {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  taxYear                      Int
  quarter                      Int   // 1-4 quarterly, 0 = annual
  grossRevenue                 Float @default(0)
  returnsAndAllowances         Float @default(0)
  netRevenue                   Float @default(0)
  totalCOGS                    Float @default(0)
  grossProfit                  Float @default(0)
  totalExpenses                Float @default(0)
  mileageDeduction             Float @default(0)
  homeOfficeDeduction          Float @default(0)
  healthInsuranceDeduction     Float @default(0)
  section199ADeduction         Float @default(0)
  totalDeductions              Float @default(0)
  netTaxableIncome             Float @default(0)
  estimatedFederalTax          Float @default(0)
  estimatedStateTax            Float @default(0)
  estimatedSelfEmploymentTax   Float @default(0)
  totalEstimatedTax            Float @default(0)
  quarterlyPayments            Json  @default("{}")
  missedDeductions             Json  @default("[]")
  taxSavingOpportunities       Json  @default("[]")
  expenseBreakdown             Json  @default("{}")
}

// ─── Profit & Loss ────────────────────────────────────────────────────────────

model ProfitAndLoss {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  period                   String // "monthly" | "quarterly" | "annual"
  startDate                String
  endDate                  String
  revenue                  Float  @default(0)
  cogs                     Float  @default(0)
  grossProfit              Float  @default(0)
  totalExpenses            Float  @default(0)
  netProfit                Float  @default(0)
  profitMargin             Float  @default(0)
  expenseBreakdown         Json   @default("{}")
  comparedToPreviousPeriod Json   @default("{}")
}

// ─── Expense Categories ───────────────────────────────────────────────────────

model ExpenseCategory {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  name             String
  description      String  @default("")
  isCustom         Boolean @default(false)
  isTaxDeductible  Boolean @default(true)
  monthlyTotal     Float   @default(0)
  yearlyTotal      Float   @default(0)
  lastUpdated      DateTime @default(now())
}

// ─── Uploaded Files ───────────────────────────────────────────────────────────

model UploadedFile {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  blobUrl    String
  blobPath   String
  fileName   String
  fileSize   Int
  mimeType   String
  folder     String // "contracts" | "receipts" | "taxes" | "insurance" | "other"

  linkedType String? // "contract" | "receipt" | "quote" | "policy_analysis"
  linkedId   String?

  analysisStatus String  @default("pending")
  analysisError  String?

  // Back-references from analysis models
  contracts      Contract[]
  receipts       Receipt[]
  policyAnalyses PolicyAnalysis[]
}

// ─── Insurance: Policy Analysis ───────────────────────────────────────────────
// Stores the raw extracted text and AI-structured summary of an uploaded
// insurance policy document.

model PolicyAnalysis {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  // Optional link to the source file
  uploadedFileId String?
  uploadedFile   UploadedFile? @relation(fields: [uploadedFileId], references: [id], onDelete: SetNull)

  rawText String? @db.Text  // Full extracted policy text
  summary Json    @default("{}") // Structured AI summary (coverage limits, deductibles, etc.)

  gapAnalyses GapAnalysis[]
}

// ─── Insurance: Gap Analysis ──────────────────────────────────────────────────
// Coverage gap analysis derived from a PolicyAnalysis and the business risk profile.

model GapAnalysis {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  policyAnalysisId String?
  policyAnalysis   PolicyAnalysis? @relation(fields: [policyAnalysisId], references: [id], onDelete: SetNull)

  results         Json @default("{}") // Array of {coverage, status, limit, recommendation}
  protectionScore Int? // 0-100 overall protection score

  coverageActionPlans CoverageActionPlan[]
}

// ─── Insurance: Coverage Action Plan ─────────────────────────────────────────
// AI-generated action plan to close coverage gaps, tied to a GapAnalysis.

model CoverageActionPlan {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  gapAnalysisId String?
  gapAnalysis   GapAnalysis? @relation(fields: [gapAnalysisId], references: [id], onDelete: SetNull)

  carrierScope         String @default("state_farm_v1")
  currentScore         Int?
  projectedScore       Int?
  planSummary          String @default("") @db.Text
  planItems            Json   @default("[]") // Array of {priority, action, product, estimatedCost, savings}
  sourceCatalogVersion String @default("state_farm_v1")
  inputHash            String @default("") // Hash of inputs for cache invalidation
}
